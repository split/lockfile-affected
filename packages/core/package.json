{
  "name": "@lockfile-affected/core",
  "version": "0.2.0",
  "description": "Core diff engine and affected package resolver",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/split/lockfile-affected"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "vitest": "*",
    "@vitest/coverage-v8": "*",
    "@types/node": "*",
    "typescript": "*"
  }
}
